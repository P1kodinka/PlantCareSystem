<Application x:Class="PlantCareSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PlantCareSystem.Converters">
    <Application.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <converters:DateToBackgroundConverter x:Key="DateToBackgroundConverter"/>
        <converters:DateToForegroundConverter x:Key="DateToForegroundConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Application.Resources>
</Application>