<Window x:Class="PlantCareSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PlantCareSystem.Views"
        Title="Система учёта агротехнических операций" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель навигации -->
        <Border Grid.Column="0" Background="#F0F0F0">
            <StackPanel Margin="10">
                <TextBlock Text="Меню" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                <Button Content="Реестр растений" Command="{Binding NavigateCommand}" CommandParameter="PlantRegistry" 
                        Margin="0,5" Padding="10,5" Background="White"/>
                <Button Content="Календарь ухода" Command="{Binding NavigateCommand}" CommandParameter="Calendar" 
                        Margin="0,5" Padding="10,5" Background="White"/>
                <Button Content="Отчёты" Command="{Binding NavigateCommand}" CommandParameter="Reports" 
                        Margin="0,5" Padding="10,5" Background="White"/>
            </StackPanel>
        </Border>

        <!-- Область контента -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="10"/>
    </Grid>
</Window>