<UserControl x:Class="PlantCareSystem.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Отчёты и экспорт" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="#F5F5F5" Padding="10" CornerRadius="5">
            <StackPanel>
                <WrapPanel Margin="0,0,0,10">
                    <TextBlock Text="Тип отчёта:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding ReportTypes}" SelectedItem="{Binding SelectedReportType}" 
                              Width="150" Margin="0,0,20,0"/>
                    <TextBlock Text="Период с:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="120" Margin="0,0,10,0"/>
                    <TextBlock Text="по:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="120" Margin="0,0,20,0"/>
                    <TextBlock Text="Растение:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding Plants}" SelectedItem="{Binding SelectedPlant}" 
                              DisplayMemberPath="Name" Width="150"/>
                </WrapPanel>
                <WrapPanel>
                    <Button Content="Экспорт в CSV" Command="{Binding ExportCsvCommand}" Width="120" Margin="0,0,10,0"/>
                    <Button Content="Экспорт в PDF" Command="{Binding ExportPdfCommand}" Width="120"/>
                    <ProgressBar IsIndeterminate="{Binding IsLoading}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" 
                                 Width="200" Height="20" Margin="20,0,0,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Здесь можно добавить предпросмотр данных, но для простоты оставим пустым -->
        <TextBlock Grid.Row="2" Text="Выберите параметры и нажмите экспорт." 
                   HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
    </Grid>
</UserControl>