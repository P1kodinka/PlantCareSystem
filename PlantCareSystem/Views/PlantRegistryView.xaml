<UserControl x:Class="PlantCareSystem.Views.PlantRegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Реестр растений" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить" Command="{Binding AddCommand}" Width="80" Margin="0,0,10,0"/>
            <Button Content="Редактировать" Command="{Binding EditCommand}" Width="100" Margin="0,0,10,0"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" Width="80" Margin="0,0,10,0"/>
            <Button Content="Активность" Command="{Binding ToggleActiveCommand}" Width="90" Margin="0,0,10,0"/>
            <CheckBox Content="Показывать неактивные" IsChecked="{Binding ShowInactive}" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="10,0,0,0" 
                     VerticalAlignment="Center" ToolTip="Поиск по названию, семейству, роду, виду, сорту"/>
            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="14"/>
        </StackPanel>

        <!-- Таблица растений -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding PlantsView}" 
                  SelectedItem="{Binding SelectedPlant}" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Семейство" Binding="{Binding Family}" Width="120"/>
                <DataGridTextColumn Header="Род" Binding="{Binding Genus}" Width="120"/>
                <DataGridTextColumn Header="Вид" Binding="{Binding Species}" Width="120"/>
                <DataGridTextColumn Header="Сорт" Binding="{Binding Variety}" Width="120"/>
                <DataGridTextColumn Header="Местоположение" Binding="{Binding Location}" Width="120"/>
                <DataGridTextColumn Header="Дата посадки" Binding="{Binding PlantingDate, StringFormat=d}" Width="100"/>
                <DataGridCheckBoxColumn Header="Активно" Binding="{Binding IsActive}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Строка состояния -->
        <StatusBar Grid.Row="3" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding Plants.Count, StringFormat='Всего растений: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>