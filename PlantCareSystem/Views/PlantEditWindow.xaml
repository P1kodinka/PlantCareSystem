<Window x:Class="PlantCareSystem.Views.PlantEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование растения" Height="550" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Название -->
                <TextBlock Text="Название *" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <!-- Семейство -->
                <TextBlock Text="Семейство" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Family, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <!-- Род -->
                <TextBlock Text="Род" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Genus, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <!-- Вид -->
                <TextBlock Text="Вид" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Species, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <!-- Сорт / разновидность -->
                <TextBlock Text="Сорт / разновидность" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Variety, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <!-- Местоположение -->
                <TextBlock Text="Местоположение" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <!-- Дата посадки -->
                <TextBlock Text="Дата посадки" Margin="0,5,0,0"/>
                <DatePicker SelectedDate="{Binding PlantingDate}" Margin="0,0,0,10"/>

                <!-- Примечания -->
                <TextBlock Text="Примечания" Margin="0,5,0,0"/>
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>

                <!-- Чекбоксы -->
                <CheckBox IsChecked="{Binding IsActive}" Content="Активно" Margin="0,5"/>
                <CheckBox IsChecked="{Binding IsRare}" Content="Редкий вид" Margin="0,5"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                    Width="80" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="Отмена" IsCancel="True" Width="80"/>
        </StackPanel>
    </Grid>
</Window>